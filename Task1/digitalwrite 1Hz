void setup() {
 
  pinMode(13, OUTPUT);
 // Setting pin 13 as output.
  // Pin 13 is connected to the onboard LED on Arduino.
}

void loop() {
  // Turn the LED on by giving pin 13 HIGH voltage
  digitalWrite(13, HIGH);
  
   delay(500);  // Wait 500 milliseconds

  digitalWrite(13, LOW);
  // Turn the LED off by giving low pin 13 LOW voltage
  

    delay(500);
  // Wait 500 ms, total cycle = 1 second = 1 Hz
  
}
